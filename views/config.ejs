<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Configuration — <%= config.portalName %></title>
  <link rel="stylesheet" href="/static/styles.css" />
</head>
<body class="admin">
  <main class="admin-wrap">
    <header class="admin-head">
      <h1>Configuration</h1>
      <div>
        <a class="btn" href="/admin<%= token ? '?token=' + token : '' %>">← Admin</a>
        <% if (hasPassword) { %><a class="btn" href="/admin/logout">Déconnexion</a><% } %>
      </div>
    </header>

    <% if (saved) { %><p class="saved">✓ Configuration enregistrée.</p><% } %>
    <% if (!configured) { %>
      <p class="error">Le contrôleur n'est pas encore configuré : renseignez la section ci-dessous pour activer l'autorisation des invités.</p>
    <% } %>

    <%
      const groupTitles = {
        controller: 'Contrôleur', unifi: 'UniFi', omada: 'Omada', portal: 'Portail',
        appearance: 'Apparence', smartschool: 'SmartSchool (OAuth)', google: 'Google (OAuth)',
        microsoft: 'Microsoft 365 (OAuth)',
      };
    %>

    <form method="POST" action="/admin/config" id="wizard">
      <input type="hidden" name="token" value="<%= token %>" />

      <div class="wiz-progress"><div class="wiz-bar" id="wizBar"></div></div>
      <p class="wiz-counter" id="wizCounter"></p>

      <% Object.keys(groups).forEach((g) => { %>
        <section class="panel wizard-step" data-group="<%= g %>">
          <h2><%= groupTitles[g] || g %></h2>
          <% groups[g].forEach((f) => { %>
            <label class="cfg-row">
              <span class="cfg-label"><%= f.label %>
                <% if (!f.overridden && f.value) { %><span class="cfg-note">(.env)</span><% } %>
                <% if (f.hint) { %><span class="cfg-hint"><%= f.hint %></span><% } %>
              </span>
              <% if (f.type === 'bool') { %>
                <select name="<%= f.key %>">
                  <option value="true" <%= String(f.value) === 'true' ? 'selected' : '' %>>Oui</option>
                  <option value="false" <%= String(f.value) !== 'true' ? 'selected' : '' %>>Non</option>
                </select>
              <% } else if (f.type === 'select') { %>
                <select name="<%= f.key %>">
                  <% f.options.forEach((o) => { %>
                    <option value="<%= o %>" <%= String(f.value) === o ? 'selected' : '' %>><%= o %></option>
                  <% }) %>
                </select>
              <% } else if (f.type === 'color') { %>
                <input type="color" name="<%= f.key %>" value="<%= f.value || '#1877f2' %>" />
              <% } else if (f.type === 'textarea') { %>
                <textarea name="<%= f.key %>" rows="5"><%= f.value %></textarea>
              <% } else if (f.secret) { %>
                <input type="password" name="<%= f.key %>" autocomplete="new-password"
                       placeholder="<%= f.isSet ? '•••••• (défini — laisser vide pour garder)' : 'non défini' %>" />
              <% } else { %>
                <input type="<%= f.type === 'number' ? 'number' : 'text' %>" name="<%= f.key %>"
                       value="<%= f.value %>" />
              <% } %>
            </label>
          <% }) %>
        </section>
      <% }) %>

      <section class="panel wizard-step" data-group="admin">
        <h2>Mot de passe administrateur</h2>
        <p class="panel-hint">
          <% if (hasPassword) { %>
            Un mot de passe est défini. Laissez vide pour le conserver, ou saisissez-en un nouveau.
          <% } else { %>
            Définissez un mot de passe pour sécuriser l'accès admin (remplace l'accès par jeton). Min. 6 caractères.
          <% } %>
        </p>
        <label class="cfg-row">
          <span class="cfg-label">Nouveau mot de passe</span>
          <input type="password" name="admin_password" autocomplete="new-password"
                 minlength="6" placeholder="<%= hasPassword ? 'inchangé' : 'à définir' %>" />
        </label>
      </section>

      <div class="wiz-nav">
        <button type="button" class="btn-secondary" id="wizPrev">← Précédent</button>
        <button type="button" id="wizNext">Suivant →</button>
        <button type="submit" id="wizSave">Enregistrer</button>
      </div>
    </form>
  </main>

  <script>
    (function () {
      const steps = Array.from(document.querySelectorAll('.wizard-step'));
      const ctrl = document.querySelector('[name="controller_type"]');
      const prev = document.getElementById('wizPrev');
      const next = document.getElementById('wizNext');
      const save = document.getElementById('wizSave');
      const bar = document.getElementById('wizBar');
      const counter = document.getElementById('wizCounter');
      let i = 0;

      // Étapes pertinentes : on masque le contrôleur non sélectionné (UniFi vs Omada).
      function activeSteps() {
        const type = ctrl ? ctrl.value : null;
        return steps.filter((s) => {
          const g = s.dataset.group;
          if (g === 'unifi' && type === 'omada') return false;
          if (g === 'omada' && type === 'unifi') return false;
          return true;
        });
      }

      function render() {
        const list = activeSteps();
        i = Math.max(0, Math.min(i, list.length - 1));
        steps.forEach((s) => { s.style.display = 'none'; });
        list.forEach((s, idx) => { if (idx === i) s.style.display = ''; });
        const last = i === list.length - 1;
        prev.style.display = i === 0 ? 'none' : '';
        next.style.display = last ? 'none' : '';
        save.style.display = last ? '' : 'none';
        bar.style.width = ((i + 1) / list.length * 100) + '%';
        counter.textContent = 'Étape ' + (i + 1) + ' / ' + list.length;
      }

      prev.addEventListener('click', function () { i -= 1; render(); });
      next.addEventListener('click', function () { i += 1; render(); });
      if (ctrl) ctrl.addEventListener('change', function () { i = 0; render(); });
      render();
    })();
  </script>
</body>
</html>
