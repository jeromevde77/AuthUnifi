<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= config.portalName %></title>
  <link rel="stylesheet" href="/static/styles.css" />
  <%- include('partials/theme') %>
</head>
<body>
  <main class="card">
    <% if (config.portalLogoUrl) { %>
      <img class="logo" src="<%= config.portalLogoUrl %>" alt="logo" />
    <% } %>
    <h1><%= config.portalWelcomeTitle || config.portalName %></h1>
    <p class="subtitle"><%= config.portalWelcomeText || 'Connectez-vous pour accéder à Internet gratuitement.' %></p>

    <% if (showBack) {
      const qs = new URLSearchParams(
        Object.fromEntries(Object.entries(params).filter(([, v]) => v))
      ).toString();
    %>
      <p class="back-link"><a href="/<%= qs ? '?' + qs : '' %>">← Autre méthode de connexion</a></p>
    <% } %>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <!-- Étape 1 : liker la page Facebook -->
    <div class="step">
      <span class="step-num">1</span>
      <span>Likez notre page Facebook</span>
    </div>
    <div class="fb-wrap">
      <iframe
        title="Page Facebook"
        src="https://www.facebook.com/plugins/page.php?href=<%= encodeURIComponent(config.facebookPageUrl) %>&tabs&width=320&height=130&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=true"
        width="320" height="130"
        style="border:none;overflow:hidden" scrolling="no" frameborder="0"
        allowfullscreen="true"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
      </iframe>
    </div>
    <p class="fb-fallback">
      Le bouton ne s'affiche pas ?
      <a href="<%= config.facebookPageUrl %>" target="_blank" rel="noopener">Ouvrir la page Facebook</a>
    </p>

    <!-- Étape 2 : email + confirmation -->
    <form method="POST" action="/authorize" class="form">
      <div class="step">
        <span class="step-num">2</span>
        <span>Entrez votre email et validez</span>
      </div>

      <input type="hidden" name="clientMac" value="<%= params.clientMac || '' %>" />
      <input type="hidden" name="apMac" value="<%= params.apMac || '' %>" />
      <input type="hidden" name="ssid" value="<%= params.ssid || '' %>" />
      <input type="hidden" name="radioId" value="<%= params.radioId || '' %>" />
      <input type="hidden" name="site" value="<%= params.site || '' %>" />
      <input type="hidden" name="redirectUrl" value="<%= params.redirectUrl || '' %>" />
      <input type="hidden" name="t" value="<%= params.t || '' %>" />

      <label for="email">Adresse email</label>
      <input type="email" id="email" name="email" placeholder="vous@exemple.com" required />

      <label class="checkbox">
        <input type="checkbox" name="liked" />
        <span>J'ai liké la page Facebook</span>
      </label>

      <button type="submit">Se connecter</button>
    </form>

    <p class="legal">
      En vous connectant, vous acceptez que votre adresse email soit collectée.
    </p>
  </main>
</body>
</html>
