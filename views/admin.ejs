<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — <%= config.portalName %></title>
  <link rel="stylesheet" href="/static/styles.css" />
</head>
<body class="admin">
  <main class="admin-wrap">
    <header class="admin-head">
      <h1>Invités collectés</h1>
      <a class="btn" href="/admin/export.csv">⬇ Export CSV</a>
    </header>

    <div class="stats">
      <div class="stat"><span class="stat-num"><%= stats.total %></span><span class="stat-label">Total</span></div>
      <div class="stat"><span class="stat-num"><%= stats.unique_emails %></span><span class="stat-label">Emails uniques</span></div>
      <div class="stat"><span class="stat-num"><%= stats.today %></span><span class="stat-label">Aujourd'hui</span></div>
    </div>

    <section class="panel">
      <h2>Méthodes de connexion</h2>
      <% if (saved) { %><p class="saved">✓ Enregistré.</p><% } %>
      <form method="POST" action="/admin/methods">
          <input type="hidden" name="token" value="<%= token %>" />
        <% methods.forEach((m) => { %>
          <label class="method-row <%= m.configured ? '' : 'disabled' %>">
            <input type="checkbox" name="method" value="<%= m.id %>"
              <%= m.enabled ? 'checked' : '' %> <%= m.configured ? '' : 'disabled' %> />
            <img class="method-icon" src="<%= m.icon %>" alt="" />
            <span class="method-label"><%= m.label %></span>
            <% if (!m.configured) { %>
              <span class="method-note"><%= m.id === 'local' ? 'aucun compte créé' : 'identifiants manquants (.env)' %></span>
            <% } %>
          </label>
        <% }) %>
        <button type="submit">Enregistrer</button>
      </form>
    </section>

    <section class="panel">
      <h2>Comptes (email + mot de passe)</h2>
      <p class="panel-hint">
        Comptes autorisés à se connecter plus longtemps via la méthode « Compte ».
        Chaque compte a sa propre durée (en minutes). Réutiliser un email existant
        met à jour son mot de passe et sa durée.
      </p>

      <table class="rules-table">
        <thead><tr><th>Email</th><th>Minutes</th><th>Créé le</th><th></th></tr></thead>
        <tbody>
          <% if (localUsers.length === 0) { %>
            <tr><td colspan="4" class="empty">Aucun compte. Ajoutez-en un pour activer la méthode.</td></tr>
          <% } %>
          <% localUsers.forEach((u) => { %>
            <tr>
              <td class="mono"><%= u.email %></td>
              <td><%= u.minutes %></td>
              <td class="mono"><%= u.created_at %></td>
              <td>
                <form method="POST" action="/admin/local-users/delete">
          <input type="hidden" name="token" value="<%= token %>" />
                  <input type="hidden" name="id" value="<%= u.id %>" />
                  <button type="submit" class="link-danger">Supprimer</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <form method="POST" action="/admin/local-users" class="rule-add">
          <input type="hidden" name="token" value="<%= token %>" />
        <input type="email" name="email" placeholder="email" required />
        <input type="password" name="password" placeholder="mot de passe" autocomplete="new-password" required />
        <input type="number" name="minutes" min="1" placeholder="minutes" required />
        <button type="submit">Ajouter</button>
      </form>
    </section>

    <% if (groupProviderIds.length) { %>
    <section class="panel">
      <h2>Durées d'accès par groupe</h2>
      <p class="panel-hint">
        Durée (en minutes) selon l'appartenance à un groupe (Google / Microsoft / SmartSchool).
        La plus longue durée l'emporte ; sinon la durée par défaut (<%= authMinutes %> min) s'applique.
      </p>

      <table class="rules-table">
        <thead><tr><th>Fournisseur</th><th>Groupe</th><th>Minutes</th><th></th></tr></thead>
        <tbody>
          <% if (groupRules.length === 0) { %>
            <tr><td colspan="4" class="empty">Aucune règle. La durée par défaut s'applique à tous.</td></tr>
          <% } %>
          <% groupRules.forEach((r) => { %>
            <tr>
              <td><%= r.provider %></td>
              <td class="mono"><%= r.group_key %></td>
              <td><%= r.minutes %></td>
              <td>
                <form method="POST" action="/admin/group-rules/delete">
          <input type="hidden" name="token" value="<%= token %>" />
                  <input type="hidden" name="id" value="<%= r.id %>" />
                  <button type="submit" class="link-danger">Supprimer</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <form method="POST" action="/admin/group-rules" class="rule-add">
          <input type="hidden" name="token" value="<%= token %>" />
        <select name="provider" required>
          <% groupProviderIds.forEach((id) => { %><option value="<%= id %>"><%= id %></option><% }) %>
        </select>
        <input type="text" name="group_key" placeholder="groupe (email / GUID / nom de classe)" required />
        <input type="number" name="minutes" min="1" placeholder="minutes" required />
        <button type="submit">Ajouter</button>
      </form>
    </section>
    <% } %>

    <div class="table-wrap">
      <% if (kicked) { %><p class="saved">✓ <%= kicked %></p><% } %>
      <% if (kickError) { %><p class="error">Déconnexion impossible : <%= kickError %></p><% } %>
      <% if (guests.some((g) => g.mac)) { %>
        <form method="POST" action="/admin/guests/unauthorize-all" style="margin:0 0 12px"
              onsubmit="return confirm('Déconnecter TOUS les invités du hotspot ?')">
          <input type="hidden" name="token" value="<%= token %>" />
          <button type="submit" class="link-danger">⎋ Déconnecter tout le monde</button>
        </form>
      <% } %>
      <table>
        <thead>
          <tr>
            <th>#</th><th>Email</th><th>Nom</th><th>Méthode</th><th>MAC</th><th>Liké</th><th>Date</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% if (guests.length === 0) { %>
            <tr><td colspan="8" class="empty">Aucun invité enregistré pour l'instant.</td></tr>
          <% } %>
          <% guests.forEach((g) => { %>
            <tr>
              <td><%= g.id %></td>
              <td><%= g.email || '—' %></td>
              <td><%= g.name || '—' %></td>
              <%
                const labels = {
                  email: '✉️ Email', local: '🔑 Compte', smartschool: '🎓 SmartSchool',
                  google: 'Ⓖ Google', microsoft: 'Ⓜ Microsoft 365',
                };
              %>
              <td><%= labels[g.method] || g.method %></td>
              <td class="mono"><%= g.mac || '—' %></td>
              <td><%= g.liked ? '✓' : '—' %></td>
              <td class="mono"><%= g.created_at %></td>
              <td>
                <% if (g.mac) { %>
                <form method="POST" action="/admin/guests/unauthorize" style="margin:0"
                      onsubmit="return confirm('Déconnecter <%= g.mac %>
          <input type="hidden" name="token" value="<%= token %>" /> ?')">
                  <input type="hidden" name="mac" value="<%= g.mac %>" />
                  <button type="submit" class="link-danger">Déconnecter</button>
                </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
