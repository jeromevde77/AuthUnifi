<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= config.portalName %></title>
  <link rel="stylesheet" href="/static/styles.css" />
</head>
<body>
  <%
    // Reconstruit la query string pour la transmettre à chaque méthode.
    const qs = new URLSearchParams(
      Object.fromEntries(Object.entries(params).filter(([, v]) => v))
    ).toString();
    const suffix = qs ? '?' + qs : '';
  %>
  <main class="card">
    <% if (config.portalLogoUrl) { %>
      <img class="logo" src="<%= config.portalLogoUrl %>" alt="logo" />
    <% } %>
    <h1><%= config.portalName %></h1>
    <p class="subtitle">Choisissez votre méthode de connexion.</p>

    <% methods.forEach((m) => { %>
      <a class="choice-btn <%= m.id %>" href="<%= m.href %><%= suffix %>">
        <span class="choice-icon"><%= m.icon %></span>
        <span><strong><%= m.label %></strong></span>
      </a>
    <% }) %>
  </main>
</body>
</html>
