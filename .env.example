# --- Serveur du portail ---
PORT=3000

# --- Contrôleur UniFi ---
# Hôte du contrôleur (UDM/UDM-Pro, Cloud Key ou contrôleur logiciel)
UNIFI_HOST=192.168.1.1
# Port : 443 pour UniFi OS (UDM/UDM-Pro/Cloud Key Gen2), 8443 pour le contrôleur logiciel classique
UNIFI_PORT=443
UNIFI_USERNAME=portal-admin
UNIFI_PASSWORD=change-me
# Nom du site UniFi (par défaut "default")
UNIFI_SITE=default
# Mettre "true" seulement si le contrôleur a un certificat TLS valide. "false" pour un certificat auto-signé.
UNIFI_SSL_VERIFY=false

# Durée d'autorisation de l'invité, en minutes (480 = 8h). Durée par défaut.
AUTH_MINUTES=480

# Durée selon l'appartenance à un groupe (SmartSchool / Google / Microsoft 365).
# Les règles se gèrent depuis le panneau admin (/admin) ; cette variable ne sert
# qu'à AMORCER la table au tout premier démarrage. JSON par fournisseur : groupe -> minutes.
# Si l'utilisateur est dans plusieurs groupes mappés, la plus longue durée l'emporte.
#  - google      : clés = email du groupe (ex. "profs@ecole.be")
#  - microsoft   : clés = GUID du groupe (ou displayName)
#  - smartschool : clés = nom/code de classe ou de groupe
# Prérequis côté admin :
#  - Google    : activer l'API Cloud Identity (le scope groupes est ajouté auto)
#  - Microsoft : consentement admin pour le scope GroupMember.Read.All
# Laisser vide si vous préférez tout configurer depuis l'admin.
# GROUP_DURATIONS={"google":{"profs@ecole.be":10080,"eleves@ecole.be":480},"microsoft":{"<guid-prof>":10080}}

# --- Méthode Email + like Facebook ---
# État par défaut (les variables ENABLE_* peuvent être surchargées à chaud
# depuis le panneau admin /admin, sans redémarrer).
ENABLE_EMAIL=true
# URL de la page Facebook à liker
FACEBOOK_PAGE_URL=https://www.facebook.com/votre-page

# --- Fournisseurs OAuth (optionnels) ---
# Un fournisseur n'apparaît que si CLIENT_ID + CLIENT_SECRET + REDIRECT_URI sont remplis.
# Désactivation explicite possible : ENABLE_<FOURNISSEUR>=false.
# Le REDIRECT_URI doit être public, en HTTPS, et déclaré côté fournisseur.

# SmartSchool — identifiants via https://www.smartschool.be/oauth/
SMARTSCHOOL_CLIENT_ID=
SMARTSCHOOL_CLIENT_SECRET=
SMARTSCHOOL_REDIRECT_URI=https://votre-portail.exemple.com/auth/smartschool/callback
SMARTSCHOOL_SCOPE=userinfo

# Google — identifiants via https://console.cloud.google.com/ (OAuth client "Web")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://votre-portail.exemple.com/auth/google/callback

# Microsoft 365 — app enregistrée sur https://entra.microsoft.com/ (Azure AD)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://votre-portail.exemple.com/auth/microsoft/callback
# "common" (multi-tenant) ou l'ID de votre tenant Azure AD :
MICROSOFT_TENANT=common

# Secret pour signer l'état OAuth (anti-CSRF). Par défaut : ADMIN_TOKEN.
SESSION_SECRET=

# --- Personnalisation ---
PORTAL_NAME=Wifi Invité
PORTAL_LOGO_URL=

# --- Administration ---
# Page d'admin : /admin  (login HTTP : ADMIN_USER / ADMIN_TOKEN)
# Export CSV : /admin/export.csv  (ou ?token=ADMIN_TOKEN)
ADMIN_USER=admin
ADMIN_TOKEN=change-this-secret-token

# --- Reverse-proxy (HTTPS) ---
# Mettre à 1 si le portail tourne derrière nginx/Caddy (1 proxy de confiance).
TRUST_PROXY=0
